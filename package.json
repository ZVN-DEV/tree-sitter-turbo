{
  "name": "tree-sitter-turbo",
  "version": "0.5.0",
  "description": "Tree-sitter grammar for the Turbo programming language",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZVN-DEV/tree-sitter-turbo"
  },
  "license": "MIT",
  "main": "bindings/node",
  "keywords": [
    "tree-sitter",
    "turbo",
    "parser"
  ],
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "tree-sitter": [
    {
      "scope": "source.turbo",
      "file-types": [
        "tb"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^turbo$"
    }
  ]
}
